{
  "extends": "./packages/config/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@jasaweb/*": ["apps/*", "packages/*"],
      "@jasaweb/ui": ["packages/ui/src"],
      "@jasaweb/ui/*": ["packages/ui/src/*"],
      "@jasaweb/config": ["packages/config/src"],
      "@jasaweb/config/*": ["packages/config/src/*"],
      "@jasaweb/testing": ["packages/testing/src"],
      "@jasaweb/testing/*": ["packages/testing/src/*"],
      "@jasaweb/api/*": ["apps/api/src/*"],
      "@jasaweb/web/*": ["apps/web/src/*"]
    },
    "jsx": "preserve"
  },
  "include": ["apps/api/**/*", "packages/**/*", "**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "dist", "**/node_modules/**", "apps/web/**/*"]
}
