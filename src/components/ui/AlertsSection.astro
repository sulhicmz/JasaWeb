---
/**
 * AlertsSection.astro
 * 
 * Displays system alerts and notifications with severity levels
 * 
 * @example
 * ```astro
 * <AlertsSection 
 *   alerts={[
 *     {
 *       severity: 'success',
 *       icon: '✅',
 *       title: 'System Health Check Passed',
 *       message: 'All components are functioning within normal parameters',
 *       timestamp: new Date(Date.now() - 120000).toISOString()
 *     }
 *   ]}
 * />
 * ```
 */

export type AlertSeverity = 'success' | 'info' | 'warning' | 'error';

export interface Alert {
  severity: AlertSeverity;
  icon: string;
  title: string;
  message: string;
  timestamp: string;
}

export interface Props {
  alerts: Alert[];
  onViewAll?: string;
}

const { alerts, onViewAll } = Astro.props;

function getSeverityColor(severity: AlertSeverity): string {
  const colors = {
    success: 'var(--color-success)',
    info: 'var(--color-primary)',
    warning: 'var(--color-secondary)',
    error: 'var(--color-error)'
  };
  return colors[severity];
}

function formatTimestamp(timestamp: string): string {
  const now = Date.now();
  const then = new Date(timestamp).getTime();
  const diff = Math.floor((now - then) / 1000);

  if (diff < 60) return 'Just now';
  if (diff < 3600) return `${Math.floor(diff / 60)} minutes ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)} hours ago`;
  return `${Math.floor(diff / 86400)} days ago`;
}
---

<section class="alerts-section" aria-labelledby="alerts-title">
  <header class="section-header">
    <h2 id="alerts-title" class="section-title">
      <span class="section-icon" aria-hidden="true">🔔</span>
      Recent Alerts
    </h2>
    {onViewAll && (
      <button 
        class="view-all-btn glass-button" 
        onclick={onViewAll}
        aria-label="View all alerts"
      >
        View All
      </button>
    )}
  </header>

  <div 
    class="alerts-list" 
    role="list" 
    aria-label="System alerts list"
  >
    {alerts.map((alert, index) => (
      <article 
        class={`alert-item ${alert.severity}`}
        role="listitem"
        aria-labelledby={`alert-title-${index}`}
        aria-describedby={`alert-message-${index}`}
      >
        <div class="alert-icon" aria-hidden="true">
          {alert.icon}
        </div>
        <div class="alert-content">
          <h3 
            id={`alert-title-${index}`}
            class="alert-title"
          >
            {alert.title}
          </h3>
          <p 
            id={`alert-message-${index}`}
            class="alert-message"
          >
            {alert.message}
          </p>
          <time 
            class="alert-time" 
            datetime={alert.timestamp}
          >
            {formatTimestamp(alert.timestamp)}
          </time>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .alerts-section {
    margin-bottom: 2rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    color: white;
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-icon {
    font-size: 1.25rem;
  }

  .view-all-btn {
    background: rgba(99, 102, 241, 0.2);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(99, 102, 241, 0.3);
    color: var(--color-primary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .view-all-btn:hover {
    background: rgba(99, 102, 241, 0.3);
    transform: translateY(-1px);
  }

  .view-all-btn:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .alerts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .alert-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-md);
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .alert-item:hover {
    transform: translateX(4px);
  }

  .alert-item.success {
    background: rgba(16, 185, 129, 0.1);
    border-left: 3px solid var(--color-success);
  }

  .alert-item.info {
    background: rgba(99, 102, 241, 0.1);
    border-left: 3px solid var(--color-primary);
  }

  .alert-item.warning {
    background: rgba(245, 158, 11, 0.1);
    border-left: 3px solid var(--color-secondary);
  }

  .alert-item.error {
    background: rgba(239, 68, 68, 0.1);
    border-left: 3px solid var(--color-error);
  }

  .alert-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .alert-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .alert-title {
    color: white;
    font-weight: 600;
    margin: 0;
    font-size: 1rem;
  }

  .alert-message {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .alert-time {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  @media (max-width: 768px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .alert-item {
      flex-direction: column;
      text-align: center;
    }

    .alert-content {
      align-items: center;
    }
  }

  @media (max-width: 480px) {
    .alerts-list {
      padding: 1rem;
    }

    .alert-item {
      padding: 0.75rem;
    }
  }
</style>
