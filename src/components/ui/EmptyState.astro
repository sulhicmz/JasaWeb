---
/**
 * Empty State Component
 * 
 * Displays a friendly message when there's no data to show. Supports
 * multiple variants (no-data, no-results, no-projects, error) with
 * customizable actions and icons.
 * 
 * @example
 * ```astro
 * <!-- Default empty state -->
 * <EmptyState
 *   title="No projects yet"
 *   description="Create your first project to get started"
 *   actionLabel="Create Project"
 *   actionHref="/projects/new"
 * />
 * 
 * <!-- Search results empty -->
 * <EmptyState
 *   variant="no-results"
 *   title="No results found"
 *   description="Try adjusting your search terms"
 * />
 * 
 * <!-- Error state -->
 * <EmptyState
 *   variant="error"
 *   title="Something went wrong"
 *   description="We couldn't load your data. Please try again."
 *   actionLabel="Retry"
 *   onAction="handleRetry()"
 * />
 * ```
 */
export interface Props {
  /** Visual variant affecting icon and styling */
  variant?: 'no-data' | 'no-results' | 'no-projects' | 'no-notifications' | 'error' | 'custom';
  /** Main heading text */
  title: string;
  /** Supporting description text */
  description?: string;
  /** Label for action button */
  actionLabel?: string;
  /** URL for action button (renders as link) */
  actionHref?: string;
  /** JavaScript to execute when action is clicked (for buttons) */
  onAction?: string;
  /** Custom SVG icon (overrides default variant icons) */
  icon?: string;
  /** Additional CSS classes to apply */
  class?: string;
}

const {
  variant = 'no-data',
  title,
  description,
  actionLabel,
  actionHref,
  onAction,
  icon: customIcon,
  class: className = '',
} = Astro.props;

const icons = {
  'no-data': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="empty-state-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
  'no-results': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="empty-state-icon"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  'no-projects': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="empty-state-icon"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
  'no-notifications': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="empty-state-icon"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  'error': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="empty-state-icon"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  'custom': customIcon || '',
};

const iconSvg = customIcon || icons[variant] || icons['no-data'];
const hasAction = actionLabel && (actionHref || onAction);
---

<div class={`empty-state empty-state-${variant} ${className}`}>
  <div class="empty-state-icon-wrapper">
    <div class="icon-container" set:html={iconSvg} />
  </div>
  {title && <h3 class="empty-state-title">{title}</h3>}
  {description && <p class="empty-state-description">{description}</p>}
  {hasAction && (
    actionHref ? (
      <a href={actionHref} class="empty-state-action">
        {actionLabel}
      </a>
    ) : (
      <button type="button" class="empty-state-action" onclick={onAction}>
        {actionLabel}
      </button>
    )
  )}
</div>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-state-icon-wrapper {
    margin-bottom: 1.5rem;
  }

  .icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    background: var(--color-bg-secondary);
    border-radius: 50%;
  }

  .empty-state-icon {
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    transition: color var(--transition-normal);
  }

  .empty-state:hover .empty-state-icon {
    color: var(--color-primary);
  }

  .empty-state-error .empty-state-icon {
    color: var(--color-error);
  }

  .empty-state-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.75rem 0;
  }

  .empty-state-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem 0;
    max-width: 400px;
    line-height: 1.5;
  }

  .empty-state-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .empty-state-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    background: var(--color-primary-dark);
  }

  @media (max-width: 640px) {
    .empty-state {
      padding: 3rem 1.5rem;
    }

    .icon-container {
      width: 64px;
      height: 64px;
    }

    .empty-state-icon {
      width: 32px;
      height: 32px;
    }

    .empty-state-title {
      font-size: 1.125rem;
    }

    .empty-state-description {
      font-size: 0.875rem;
      max-width: 100%;
    }
  }
</style>
