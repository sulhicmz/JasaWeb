<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Congratulations! Onboarding Complete</title>
</head>
<body>
  <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 30px;">
      <div style="font-size: 48px; margin-bottom: 15px;">🎉</div>
      <h1 style="color: #2563eb; margin: 0; font-size: 28px;">Congratulations, {{name}}!</h1>
      <p style="color: #6b7280; margin: 10px 0 0 0; font-size: 16px;">You've successfully completed onboarding</p>
    </div>

    <!-- Success Message -->
    <div style="background: #f0fdf4; border: 1px solid #22c55e; border-radius: 8px; padding: 20px; margin-bottom: 25px;">
      <h2 style="color: #166534; margin: 0 0 10px 0;">🚀 You're All Set!</h2>
      <p style="color: #166534; margin: 0; line-height: 1.6;">
        Your JasaWeb account is fully configured and ready to go. You now have access to all the powerful features 
        that will help you create amazing websites and manage projects efficiently.
      </p>
    </div>

    <!-- What You Can Do Now -->
    <div style="margin-bottom: 25px;">
      <h3 style="color: #1f2937; margin: 0 0 15px 0;">What you can do now:</h3>
      
      <div style="display: grid; gap: 12px;">
        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px;">
          <div style="display: flex; align-items: flex-start;">
            <div style="background: #2563eb; color: white; width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0;">
              📊
            </div>
            <div>
              <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 15px;">View Your Dashboard</h4>
              <p style="color: #6b7280; margin: 0; font-size: 13px;">Get an overview of your projects and recent activity</p>
            </div>
          </div>
        </div>

        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px;">
          <div style="display: flex; align-items: flex-start;">
            <div style="background: #2563eb; color: white; width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0;">
              🚀
            </div>
            <div>
              <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 15px;">Launch New Projects</h4>
              <p style="color: #6b7280; margin: 0; font-size: 13px;">Start creating websites and managing development</p>
            </div>
          </div>
        </div>

        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px;">
          <div style="display: flex; align-items: flex-start;">
            <div style="background: #2563eb; color: white; width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0;">
              👥
            </div>
            <div>
              <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 15px;">Collaborate with Your Team</h4>
              <p style="color: #6b7280; margin: 0; font-size: 13px;">Share files, get approvals, and track progress together</p>
            </div>
          </div>
        </div>

        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px;">
          <div style="display: flex; align-items: flex-start;">
            <div style="background: #2563eb; color: white; width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0;">
              📁
            </div>
            <div>
              <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 15px;">Manage Files Securely</h4>
              <p style="color: #6b7280; margin: 0; font-size: 13px;">Upload, organize, and share project assets</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div style="text-align: center; margin-bottom: 25px;">
      <h3 style="color: #1f2937; margin: 0 0 15px 0;">Ready to dive in?</h3>
      <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
        <a href="{{dashboardUrl}}" style="background: #2563eb; color: white; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 14px;">
          Go to Dashboard
        </a>
        <a href="{{newProjectUrl}}" style="background: #10b981; color: white; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 14px;">
          New Project
        </a>
        <a href="{{helpCenterUrl}}" style="background: #6b7280; color: white; padding: 10px 20px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 14px;">
          Get Help
        </a>
      </div>
    </div>

    <!-- Pro Tips -->
    <div style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
      <h4 style="color: #92400e; margin: 0 0 8px 0; font-size: 14px;">💡 Pro Tips for Success</h4>
      <ul style="color: #92400e; margin: 0; padding-left: 20px; font-size: 13px; line-height: 1.5;">
        <li>Set up project templates to streamline future work</li>
        <li>Use milestones to break large projects into manageable chunks</li>
        <li>Enable email notifications to stay updated on project activity</li>
        <li>Invite team members early to foster collaboration</li>
      </ul>
    </div>

    <!-- Stats -->
    {{#if onboardingStats}}
    <div style="background: #f8fafc; border-radius: 8px; padding: 20px; margin-bottom: 25px;">
      <h4 style="color: #1f2937; margin: 0 0 12px 0; text-align: center;">Your Onboarding Stats</h4>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; text-align: center;">
        <div>
          <div style="font-size: 24px; font-weight: bold; color: #2563eb;">{{onboardingStats.stepsCompleted}}</div>
          <div style="font-size: 12px; color: #6b7280;">Steps Completed</div>
        </div>
        <div>
          <div style="font-size: 24px; font-weight: bold; color: #10b981;">{{onboardingStats.timeSpent}}</div>
          <div style="font-size: 12px; color: #6b7280;">Time Spent</div>
        </div>
        <div>
          <div style="font-size: 24px; font-weight: bold; color: #f59e0b;">{{onboardingStats.projectsCreated}}</div>
          <div style="font-size: 12px; color: #6b7280;">Projects Created</div>
        </div>
      </div>
    </div>
    {{/if}}

    <!-- Support -->
    <div style="text-align: center; padding: 20px; background: #f9fafb; border-radius: 8px;">
      <h4 style="color: #1f2937; margin: 0 0 8px 0;">We're Here for You!</h4>
      <p style="color: #6b7280; margin: 0 0 12px 0; font-size: 14px;">
        Have questions? Our support team is ready to help you make the most of JasaWeb.
      </p>
      <div style="display: flex; justify-content: center; gap: 15px;">
        <a href="{{supportUrl}}" style="color: #2563eb; text-decoration: none; font-size: 14px;">Visit Help Center</a>
        <span style="color: #d1d5db;">•</span>
        <a href="mailto:support@jasaweb.com" style="color: #2563eb; text-decoration: none; font-size: 14px;">Email Support</a>
        <span style="color: #d1d5db;">•</span>
        <a href="{{scheduleCallUrl}}" style="color: #2563eb; text-decoration: none; font-size: 14px;">Schedule a Call</a>
      </div>
    </div>

    <!-- Footer -->
    <div style="text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #e5e7eb;">
      <p style="color: #6b7280; margin: 0; font-size: 12px;">
        Here's to your success!<br>
        <strong>The JasaWeb Team</strong>
      </p>
    </div>
  </div>
</body>
</html>