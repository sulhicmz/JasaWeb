<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Start Your Journey with JasaWeb</title>
</head>
<body>
  <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 30px;">
      <h1 style="color: #2563eb; margin: 0; font-size: 28px;">🚀 Let's Get Started!</h1>
      <p style="color: #6b7280; margin: 10px 0 0 0; font-size: 16px;">Your JasaWeb onboarding journey begins now</p>
    </div>

    <!-- Welcome Message -->
    <div style="background: #f8fafc; border-radius: 8px; padding: 20px; margin-bottom: 25px;">
      <h2 style="color: #1f2937; margin: 0 0 10px 0;">Welcome aboard, {{name}}!</h2>
      <p style="color: #4b5563; margin: 0; line-height: 1.6;">
        We're excited to help you create amazing websites and streamline your project management. 
        Our guided onboarding process will have you up and running in just a few minutes.
      </p>
    </div>

    <!-- Onboarding Steps -->
    <div style="margin-bottom: 25px;">
      <h3 style="color: #1f2937; margin: 0 0 15px 0;">What to expect:</h3>
      
      <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; margin-bottom: 10px;">
        <div style="display: flex; align-items: center;">
          <div style="background: #2563eb; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 12px;">1</div>
          <div>
            <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 14px;">Set Up Your Organization</h4>
            <p style="color: #6b7280; margin: 0; font-size: 13px;">Configure your profile and basic settings</p>
          </div>
        </div>
      </div>

      <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; margin-bottom: 10px;">
        <div style="display: flex; align-items: center;">
          <div style="background: #2563eb; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 12px;">2</div>
          <div>
            <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 14px;">Invite Your Team</h4>
            <p style="color: #6b7280; margin: 0; font-size: 13px;">Add collaborators and assign roles</p>
          </div>
        </div>
      </div>

      <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; margin-bottom: 10px;">
        <div style="display: flex; align-items: center;">
          <div style="background: #2563eb; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 12px;">3</div>
          <div>
            <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 14px;">Create Your First Project</h4>
            <p style="color: #6b7280; margin: 0; font-size: 13px;">Set up milestones and deliverables</p>
          </div>
        </div>
      </div>

      <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px;">
        <div style="display: flex; align-items: center;">
          <div style="background: #2563eb; color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 12px;">4</div>
          <div>
            <h4 style="color: #1f2937; margin: 0 0 4px 0; font-size: 14px;">Platform Tour</h4>
            <p style="color: #6b7280; margin: 0; font-size: 13px;">Discover key features and shortcuts</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Button -->
    <div style="text-align: center; margin-bottom: 25px;">
      <a href="{{onboardingUrl}}" style="background: #2563eb; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold; display: inline-block;">
        Start Onboarding
      </a>
    </div>

    <!-- Tips -->
    <div style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
      <h4 style="color: #92400e; margin: 0 0 8px 0; font-size: 14px;">💡 Pro Tip</h4>
      <p style="color: #92400e; margin: 0; font-size: 13px; line-height: 1.5;">
        The entire onboarding process takes about 10 minutes. You can always skip optional steps and complete them later!
      </p>
    </div>

    <!-- Support -->
    <div style="text-align: center; padding: 20px; background: #f9fafb; border-radius: 8px;">
      <h4 style="color: #1f2937; margin: 0 0 8px 0;">Need Help?</h4>
      <p style="color: #6b7280; margin: 0 0 12px 0; font-size: 14px;">
        Our support team is here to assist you every step of the way.
      </p>
      <div style="display: flex; justify-content: center; gap: 15px;">
        <a href="{{supportUrl}}" style="color: #2563eb; text-decoration: none; font-size: 14px;">Visit Help Center</a>
        <span style="color: #d1d5db;">•</span>
        <a href="mailto:support@jasaweb.com" style="color: #2563eb; text-decoration: none; font-size: 14px;">Email Support</a>
      </div>
    </div>

    <!-- Footer -->
    <div style="text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #e5e7eb;">
      <p style="color: #6b7280; margin: 0; font-size: 12px;">
        Best regards,<br>
        <strong>The JasaWeb Team</strong>
      </p>
    </div>
  </div>
</body>
</html>