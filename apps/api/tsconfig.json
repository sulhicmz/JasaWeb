{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": false,
    "module": "ES2022",
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
    // IMPORTANT: Do NOT exclude any source directories from compilation
    // All critical application directories (approvals, files, tickets, invoices, milestones, projects, common/database)
    // must be included in TypeScript compilation for type safety and error detection
    // See issue #79 and verify-typescript-config.js for validation
  ]
}
