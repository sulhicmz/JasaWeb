{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
    // Note: Core application directories (approvals, files, tickets, invoices, milestones, projects, common/database)
    // should NEVER be excluded from TypeScript compilation to ensure type safety and catch errors early.
    // Only exclude build artifacts and external dependencies.
  ]
}
