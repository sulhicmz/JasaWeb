{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": false,
    "module": "ES2022",
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist"
    // IMPORTANT: All application source code should be included in compilation.
    // Only exclude external dependencies and build artifacts.
    // Critical directories like approvals, files, tickets, invoices, milestones,
    // projects, and common/database MUST remain included for type safety.
  ]
}
