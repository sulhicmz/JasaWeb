# Application Configuration
APP_NAME=JasaWeb
NODE_ENV=development
API_PORT=3000
API_PREFIX=api
API_BASE_URL=http://localhost:3000
API_DOCS_URL=http://localhost:3000/api/docs
API_TIMEOUT=30000

# Database Configuration
DATABASE_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@localhost:5432/jasaweb?schema=public
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000

# JWT Configuration
# SECURITY WARNING: JWT_SECRET must be set in production and should be at least 32 characters long
# Never use the example value in production - generate a cryptographically secure random string
JWT_SECRET=CHANGE_THIS_32_CHARACTER_RANDOM_STRING
JWT_EXPIRY=1h
JWT_REFRESH_SECRET=CHANGE_THIS_32_CHARACTER_RANDOM_STRING
JWT_REFRESH_EXPIRY=7d

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_PREVENT_REUSE=5

# Account Lockout
ACCOUNT_LOCKOUT_ENABLED=true
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
LOCKOUT_RESET_AFTER_MINUTES=60

# CORS Configuration
CORS_ORIGIN=http://localhost:4321,http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_TTL=900
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_TTL=60
API_RATE_LIMIT_MAX=100

# Cache Configuration
CACHE_TTL=5
CACHE_MAX=100

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_THIS_EMAIL_ADDRESS
SMTP_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD
SMTP_FROM=noreply@jasaweb.com

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_THIS_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_THIS_AWS_SECRET_KEY
AWS_S3_BUCKET=jasaweb-uploads

# MinIO Configuration (Alternative to S3)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=CHANGE_THIS_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_THIS_MINIO_SECRET_KEY
MINIO_BUCKET=jasaweb-uploads

# Session Configuration
SESSION_SECRET=CHANGE_THIS_32_CHARACTER_RANDOM_STRING
SESSION_MAX_AGE=86400000

# Security Configuration
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000
ENCRYPTION_KEY=CHANGE_THIS_32_CHARACTER_ENCRYPTION_KEY

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_AUDIT_LOG=true
ENABLE_EMAIL_NOTIFICATIONS=true
