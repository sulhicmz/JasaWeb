# =============================================================================
# JasaWeb API Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# SECURITY WARNING: Never commit actual secrets to version control!

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000

# Application Metadata
APP_NAME=JasaWeb API
APP_VERSION=1.0.0

# API URLs
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4321
API_PREFIX=api
API_VERSION=v1
API_TIMEOUT=30000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@localhost:5432/jasaweb?schema=public

# Database Connection Pool
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=30000
DATABASE_QUERY_TIMEOUT=30000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Configuration - CRITICAL: Generate secure random strings for production!
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_32_CHARACTER_RANDOM_STRING_MINIMUM
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_THIS_32_CHARACTER_RANDOM_STRING_MINIMUM
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=CHANGE_THIS_32_CHARACTER_RANDOM_STRING_MINIMUM
SESSION_MAX_AGE_HOURS=24
SESSION_ABSOLUTE_TIMEOUT_HOURS=72
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# Password Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_PREVENT_REUSE=5

# Account Lockout
ACCOUNT_LOCKOUT_ENABLED=true
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
LOCKOUT_RESET_AFTER_MINUTES=60

# Encryption
ENCRYPTION_KEY=CHANGE_THIS_32_CHARACTER_EXACT_KEY
ENCRYPTION_ALGORITHM=aes-256-gcm

# =============================================================================
# CORS & RATE LIMITING
# =============================================================================
CORS_ORIGIN=http://localhost:4321,http://localhost:3000

# Global Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Authentication Rate Limiting (stricter)
AUTH_RATE_LIMIT_TTL=900
AUTH_RATE_LIMIT_MAX=5

# API Rate Limiting
API_RATE_LIMIT_TTL=60
API_RATE_LIMIT_MAX=100

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Cache TTL increased from 5 seconds to 5 minutes for better performance
CACHE_TTL=300
CACHE_MAX=1000

# Redis Configuration (optional but recommended for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=jasaweb:
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_DESTINATION=./uploads

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=CHANGE_THIS_EMAIL_ADDRESS
EMAIL_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD
EMAIL_FROM=noreply@jasaweb.com
EMAIL_TEMPLATES_PATH=./templates

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
MONITORING_ENABLED=true
METRICS_PATH=/metrics
HEALTH_CHECK_PATH=/health

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_REGISTRATION=true
FEATURE_EMAIL_VERIFICATION=true
FEATURE_PASSWORD_RESET=true
FEATURE_MULTI_TENANCY=true
FEATURE_ANALYTICS=true
FEATURE_KNOWLEDGE_BASE=true
FEATURE_FILE_MANAGEMENT=true
FEATURE_APPROVALS=true
FEATURE_INVOICES=true

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
COMPANY_NAME=JasaWeb
COMPANY_EMAIL=contact@jasaweb.com
COMPANY_PHONE=+62-21-1234-5678
COMPANY_ADDRESS=Jakarta, Indonesia
COMPANY_WEBSITE=https://jasaweb.com

# Service Pricing (in Indonesian Rupiah)
SCHOOL_WEBSITE_BASE_PRICE=15000000
SCHOOL_WEBSITE_DELIVERY_WEEKS=8
NEWS_PORTAL_BASE_PRICE=20000000
NEWS_PORTAL_DELIVERY_WEEKS=10
COMPANY_PROFILE_BASE_PRICE=10000000
COMPANY_PROFILE_DELIVERY_WEEKS=6

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=jasaweb-uploads

# MinIO Configuration (S3-compatible alternative)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jasaweb-uploads

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 1. Always use strong, unique secrets in production
# 2. Generate secrets with: openssl rand -base64 32
# 3. ENCRYPTION_KEY must be exactly 32 characters
# 4. Increase BCRYPT_ROUNDS to 12-15 for better security
# 5. Set appropriate CORS origins for your domain in production
# 6. Configure Redis for production environments
# 7. Set up proper email service for transactional emails
# 8. Configure file storage (S3/MinIO) for production