{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "test",
    "node_modules",
    "dist"
    // Note: Only exclude test files and build artifacts from production build.
    // All source code including core modules must be included for proper compilation.
  ]
}
