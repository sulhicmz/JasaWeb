---
// src/components/onboarding/ProjectTemplates.astro
export interface Props {
  selectedTemplate?: string;
  onTemplateSelect?: (template: string) => void;
}

const { selectedTemplate, onTemplateSelect } = Astro.props;

// Project templates configuration
const projectTemplates = [
  {
    id: 'school',
    name: 'Website Sekolah',
    description: 'Template lengkap untuk website institusi pendidikan',
    icon: '🏫',
    duration: '2-3 bulan',
    milestones: 15,
    features: [
      'Halaman Beranda',
      'Profil Sekolah',
      'Informasi PPDB',
      'Galeri Foto',
      'Berita & Pengumuman',
      'Kontak & Lokasi'
    ],
    color: 'blue'
  },
  {
    id: 'portal',
    name: 'Portal Berita',
    description: 'Template untuk portal berita dan konten',
    icon: '📰',
    duration: '1-2 bulan',
    milestones: 10,
    features: [
      'Halaman Utama',
      'Kategori Berita',
      'Artikel Detail',
      'Pencarian',
      'Komentar',
      'Newsletter'
    ],
    color: 'green'
  },
  {
    id: 'company',
    name: 'Company Profile',
    description: 'Template profesional untuk website perusahaan',
    icon: '🏢',
    duration: '1-2 bulan',
    milestones: 8,
    features: [
      'Landing Page',
      'Tentang Kami',
      'Layanan',
      'Portfolio',
      'Tim',
      'Kontak'
    ],
    color: 'purple'
  },
  {
    id: 'ecommerce',
    name: 'E-Commerce',
    description: 'Template toko online lengkap',
    icon: '🛒',
    duration: '2-3 bulan',
    milestones: 20,
    features: [
      'Katalog Produk',
      'Shopping Cart',
      'Checkout',
      'Payment Gateway',
      'User Account',
      'Order Tracking'
    ],
    color: 'orange'
  },
  {
    id: 'custom',
    name: 'Custom Project',
    description: 'Mulai dari awal dengan konfigurasi kustom',
    icon: '🎨',
    duration: 'Flexible',
    milestones: 'Custom',
    features: [
      'Desain Kustom',
      'Fitur Kustom',
      'Integrasi Kustom',
      'API Development',
      'Maintenance',
      'Support'
    ],
    color: 'gray'
  }
];
---

<!-- Project Templates Grid -->
<div class="project-templates-grid">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      projectTemplates.map((template) => (
        <div 
          class={`project-template-card border-2 rounded-lg p-6 cursor-pointer transition-all duration-200 hover:shadow-lg ${
            selectedTemplate === template.id 
              ? `border-${template.color}-500 bg-${template.color}-50` 
              : 'border-gray-200 hover:border-gray-300'
          }`}
          data-template-id={template.id}
          onclick={`selectTemplate('${template.id}')`}
        >
          <!-- Template Header -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center space-x-3">
              <div class={`w-12 h-12 bg-${template.color}-100 rounded-lg flex items-center justify-center`}>
                <span class="text-2xl">{template.icon}</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{template.name}</h3>
                <p class="text-sm text-gray-600">{template.duration}</p>
              </div>
            </div>
            
            {selectedTemplate === template.id && (
              <div class={`w-6 h-6 bg-${template.color}-500 rounded-full flex items-center justify-center`}>
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
            )}
          </div>
          
          <!-- Template Description -->
          <p class="text-sm text-gray-600 mb-4">{template.description}</p>
          
          <!-- Template Stats -->
          <div class="flex items-center space-x-4 mb-4">
            <div class="flex items-center space-x-1">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="text-xs text-gray-500">{template.duration}</span>
            </div>
            <div class="flex items-center space-x-1">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
              <span class="text-xs text-gray-500">{template.milestones} milestone</span>
            </div>
          </div>
          
          <!-- Template Features -->
          <div class="space-y-2">
            <h4 class="text-xs font-semibold text-gray-700 uppercase tracking-wider">Fitur Utama</h4>
            <div class="grid grid-cols-2 gap-2">
              {template.features.slice(0, 4).map((feature) => (
                <div class="flex items-center space-x-1">
                  <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-xs text-gray-600">{feature}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
  
  <!-- Template Details Modal -->
  <div id="templateDetailsModal" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black bg-opacity-50"></div>
    <div class="fixed inset-0 overflow-y-auto">
      <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-4xl bg-white rounded-lg shadow-xl">
          <!-- Modal Header -->
          <div class="px-6 py-4 border-b border-gray-200">
            <div class="flex items-center justify-between">
              <h3 class="text-xl font-semibold text-gray-900" id="modalTemplateName">Template Name</h3>
              <button 
                onclick="closeTemplateDetails()"
                class="text-gray-400 hover:text-gray-600 transition-colors"
              >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
          </div>
          
          <!-- Modal Content -->
          <div class="px-6 py-6">
            <div id="modalTemplateContent">
              <!-- Dynamic content will be loaded here -->
            </div>
          </div>
          
          <!-- Modal Footer -->
          <div class="px-6 py-4 border-t border-gray-200 bg-gray-50">
            <div class="flex justify-end space-x-3">
              <button 
                onclick="closeTemplateDetails()"
                class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors"
              >
                Batal
              </button>
              <button 
                onclick="useSelectedTemplate()"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors"
              >
                Gunakan Template
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script client:load>
  class ProjectTemplates {
    constructor() {
      this.templates = [
        {
          id: 'school',
          name: 'Website Sekolah',
          description: 'Template lengkap untuk website institusi pendidikan',
          icon: '🏫',
          duration: '2-3 bulan',
          milestones: 15,
          features: [
            'Halaman Beranda',
            'Profil Sekolah',
            'Informasi PPDB',
            'Galeri Foto',
            'Berita & Pengumuman',
            'Kontak & Lokasi'
          ],
          color: 'blue',
          milestonesList: [
            'Kick-off Meeting & Requirements Gathering',
            'UI/UX Design & Mockup Creation',
            'Homepage Development',
            'School Profile Pages',
            'PPDB Information System',
            'Photo Gallery Implementation',
            'News & Announcement System',
            'Contact & Location Pages',
            'Responsive Design Implementation',
            'Content Management Setup',
            'Testing & Quality Assurance',
            'Client Training & Documentation',
            'Deployment & Go-Live',
            'Post-Launch Support (1 week)',
            'Project Handover'
          ]
        },
        {
          id: 'portal',
          name: 'Portal Berita',
          description: 'Template untuk portal berita dan konten',
          icon: '📰',
          duration: '1-2 bulan',
          milestones: 10,
          features: [
            'Halaman Utama',
            'Kategori Berita',
            'Artikel Detail',
            'Pencarian',
            'Komentar',
            'Newsletter'
          ],
          color: 'green',
          milestonesList: [
            'Requirements & Design Planning',
            'Database Schema Design',
            'Homepage Layout Development',
            'Category Management System',
            'Article Creation & Editing',
            'Search Implementation',
            'Comment System',
            'Newsletter Subscription',
            'Testing & Optimization',
            'Launch & Deployment'
          ]
        },
        {
          id: 'company',
          name: 'Company Profile',
          description: 'Template profesional untuk website perusahaan',
          icon: '🏢',
          duration: '1-2 bulan',
          milestones: 8,
          features: [
            'Landing Page',
            'Tentang Kami',
            'Layanan',
            'Portfolio',
            'Tim',
            'Kontak'
          ],
          color: 'purple',
          milestonesList: [
            'Discovery & Planning',
            'Design Concept Creation',
            'Landing Page Development',
            'About Us Pages',
            'Services Section',
            'Portfolio Showcase',
            'Team & Contact Pages',
            'Final Testing & Launch'
          ]
        },
        {
          id: 'ecommerce',
          name: 'E-Commerce',
          description: 'Template toko online lengkap',
          icon: '🛒',
          duration: '2-3 bulan',
          milestones: 20,
          features: [
            'Katalog Produk',
            'Shopping Cart',
            'Checkout',
            'Payment Gateway',
            'User Account',
            'Order Tracking'
          ],
          color: 'orange',
          milestonesList: [
            'Business Analysis & Planning',
            'UI/UX Design',
            'Product Catalog Setup',
            'Shopping Cart Development',
            'User Account System',
            'Checkout Process',
            'Payment Gateway Integration',
            'Order Management',
            'Admin Panel Development',
            'Search & Filter System',
            'Review & Rating System',
            'Wishlist Implementation',
            'Email Notification System',
            'Mobile Responsiveness',
            'Performance Optimization',
            'Security Implementation',
            'Testing Phase',
            'Content Migration',
            'Training & Documentation',
            'Launch & Support'
          ]
        },
        {
          id: 'custom',
          name: 'Custom Project',
          description: 'Mulai dari awal dengan konfigurasi kustom',
          icon: '🎨',
          duration: 'Flexible',
          milestones: 'Custom',
          features: [
            'Desain Kustom',
            'Fitur Kustom',
            'Integrasi Kustom',
            'API Development',
            'Maintenance',
            'Support'
          ],
          color: 'gray',
          milestonesList: [
            'Custom requirements gathering',
            'Tailored design process',
            'Custom feature development',
            'Specific integrations',
            'API development as needed',
            'Flexible timeline management',
            'Custom testing procedures',
            'Ongoing maintenance plan'
          ]
        }
      ];
      
      this.selectedTemplate = null;
      this.init();
    }
    
    init() {
      this.bindEvents();
    }
    
    bindEvents() {
      // Template card clicks are handled by onclick attributes
    }
    
    selectTemplate(templateId) {
      this.selectedTemplate = templateId;
      
      // Update UI
      document.querySelectorAll('.project-template-card').forEach(card => {
        card.classList.remove('border-blue-500', 'bg-blue-50');
        card.classList.add('border-gray-200');
      });
      
      const selectedCard = document.querySelector(`[data-template-id="${templateId}"]`);
      if (selectedCard) {
        const template = this.templates.find(t => t.id === templateId);
        selectedCard.classList.remove('border-gray-200');
        selectedCard.classList.add(`border-${template.color}-500`, `bg-${template.color}-50`);
      }
      
      // Show template details
      this.showTemplateDetails(templateId);
    }
    
    showTemplateDetails(templateId) {
      const template = this.templates.find(t => t.id === templateId);
      if (!template) return;
      
      const modal = document.getElementById('templateDetailsModal');
      const modalTitle = document.getElementById('modalTemplateName');
      const modalContent = document.getElementById('modalTemplateContent');
      
      if (!modal || !modalTitle || !modalContent) return;
      
      modalTitle.textContent = template.name;
      
      modalContent.innerHTML = `
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Template Overview -->
          <div>
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-16 h-16 bg-${template.color}-100 rounded-lg flex items-center justify-center">
                <span class="text-3xl">${template.icon}</span>
              </div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900">${template.name}</h4>
                <p class="text-gray-600">${template.description}</p>
              </div>
            </div>
            
            <div class="space-y-4">
              <div>
                <h5 class="font-semibold text-gray-900 mb-2">Estimasi Durasi</h5>
                <p class="text-gray-600">${template.duration}</p>
              </div>
              
              <div>
                <h5 class="font-semibold text-gray-900 mb-2">Jumlah Milestone</h5>
                <p class="text-gray-600">${template.milestones} milestone</p>
              </div>
              
              <div>
                <h5 class="font-semibold text-gray-900 mb-2">Fitur Utama</h5>
                <ul class="space-y-2">
                  ${template.features.map(feature => `
                    <li class="flex items-center space-x-2">
                      <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      <span class="text-gray-600">${feature}</span>
                    </li>
                  `).join('')}
                </ul>
              </div>
            </div>
          </div>
          
          <!-- Milestones -->
          <div>
            <h5 class="font-semibold text-gray-900 mb-4">Rencana Milestone</h5>
            <div class="space-y-3 max-h-96 overflow-y-auto">
              ${template.milestonesList.map((milestone, index) => `
                <div class="flex items-start space-x-3 p-3 bg-gray-50 rounded-lg">
                  <div class="w-6 h-6 bg-${template.color}-500 text-white rounded-full flex items-center justify-center text-xs font-semibold flex-shrink-0">
                    ${index + 1}
                  </div>
                  <p class="text-sm text-gray-700">${milestone}</p>
                </div>
              `).join('')}
            </div>
          </div>
        </div>
      `;
      
      modal.classList.remove('hidden');
    }
    
    closeTemplateDetails() {
      const modal = document.getElementById('templateDetailsModal');
      if (modal) {
        modal.classList.add('hidden');
      }
    }
    
    useSelectedTemplate() {
      if (!this.selectedTemplate) return;
      
      // Store selected template
      localStorage.setItem('selectedProjectTemplate', this.selectedTemplate);
      
      // Close modal
      this.closeTemplateDetails();
      
      // Show success message
      this.showMessage(`Template "${this.templates.find(t => t.id === this.selectedTemplate).name}" telah dipilih!`, 'success');
      
      // Trigger callback if exists
      if (typeof window.onTemplateSelect === 'function') {
        window.onTemplateSelect(this.selectedTemplate);
      }
    }
    
    showMessage(message, type = 'info') {
      const messageEl = document.createElement('div');
      messageEl.className = `fixed top-4 right-4 z-50 p-4 rounded-md shadow-lg ${
        type === 'success' ? 'bg-green-500 text-white' : 
        type === 'error' ? 'bg-red-500 text-white' : 
        'bg-blue-500 text-white'
      }`;
      messageEl.textContent = message;
      
      document.body.appendChild(messageEl);
      
      setTimeout(() => {
        messageEl.remove();
      }, 3000);
    }
  }
  
  // Global functions for onclick handlers
  window.selectTemplate = function(templateId) {
    const templates = new ProjectTemplates();
    templates.selectTemplate(templateId);
  };
  
  window.closeTemplateDetails = function() {
    const templates = new ProjectTemplates();
    templates.closeTemplateDetails();
  };
  
  window.useSelectedTemplate = function() {
    const templates = new ProjectTemplates();
    templates.useSelectedTemplate();
  };
  
  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    new ProjectTemplates();
  });
</script>