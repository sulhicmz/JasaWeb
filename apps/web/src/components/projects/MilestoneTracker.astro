---
// Milestone Tracker Component
---

<div class="space-y-6">
  <!-- Tracker Header -->
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <h3 class="text-white font-medium">Milestone Progress</h3>
      <div class="flex items-center space-x-2">
        <span class="text-sm text-slate-400">Filter:</span>
        <select id="milestoneFilter" class="bg-slate-800 text-white px-3 py-1 rounded-lg border border-slate-700 focus:border-blue-500 focus:outline-none text-sm">
          <option value="all">All Projects</option>
          <option value="active">Active</option>
          <option value="completed">Completed</option>
        </select>
      </div>
    </div>
    <div class="flex items-center space-x-2">
      <button class="p-2 hover:bg-slate-700 rounded-lg transition-colors" onclick="milestoneTracker.refresh()" title="Refresh">
        <i class="fas fa-sync-alt text-slate-400"></i>
      </button>
      <button class="p-2 hover:bg-slate-700 rounded-lg transition-colors" onclick="milestoneTracker.exportData()" title="Export">
        <i class="fas fa-download text-slate-400"></i>
      </button>
    </div>
  </div>

  <!-- Progress Overview -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="glass-panel p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-white" id="totalMilestones">0</div>
      <div class="text-sm text-slate-400">Total Milestones</div>
    </div>
    <div class="glass-panel p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-green-400" id="completedMilestones">0</div>
      <div class="text-sm text-slate-400">Completed</div>
    </div>
    <div class="glass-panel p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-blue-400" id="inProgressMilestones">0</div>
      <div class="text-sm text-slate-400">In Progress</div>
    </div>
    <div class="glass-panel p-4 rounded-lg text-center">
      <div class="text-2xl font-bold text-red-400" id="overdueMilestones">0</div>
      <div class="text-sm text-slate-400">Overdue</div>
    </div>
  </div>

  <!-- Milestone Progress by Project -->
  <div class="glass-panel p-6 rounded-xl">
    <h4 class="text-white font-medium mb-4">Project Milestone Progress</h4>
    <div class="space-y-4" id="projectMilestoneProgress">
      <!-- Project progress will be populated here -->
    </div>
  </div>

  <!-- Detailed Milestone List -->
  <div class="glass-panel p-6 rounded-xl">
    <h4 class="text-white font-medium mb-4">Milestone Details</h4>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Milestone</th>
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Project</th>
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Due Date</th>
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Status</th>
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Progress</th>
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Assignee</th>
            <th class="text-left py-3 px-4 text-slate-400 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody id="milestoneTableBody">
          <!-- Milestone rows will be populated here -->
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  class MilestoneTracker {
    private milestones: any[] = [];
    private projects: any[] = [];
    private currentFilter = 'all';

    constructor() {
      this.loadData();
      this.setupEventListeners();
    }

    private async loadData() {
      try {
        // Load projects and milestones
        const [projectsResponse, milestonesResponse] = await Promise.all([
          fetch('/api/dashboard/projects-overview'),
          fetch('/api/milestones')
        ]);

        this.projects = await projectsResponse.json();
        this.milestones = await milestonesResponse.json();

        // Enrich milestones with project data
        this.milestones = this.milestones.map((milestone: any) => {
          const project = this.projects.find(p => p.id === milestone.projectId);
          return {
            ...milestone,
            projectName: project?.name || 'Unknown Project',
            projectStatus: project?.status || 'unknown'
          };
        });

        this.updateUI();
      } catch (error) {
        console.error('Failed to load milestone data:', error);
        this.loadMockData();
      }
    }

    private updateUI() {
      this.updateOverviewStats();
      this.updateProjectProgress();
      this.updateMilestoneTable();
    }

    private updateOverviewStats() {
      const filteredMilestones = this.getFilteredMilestones();
      
      const total = filteredMilestones.length;
      const completed = filteredMilestones.filter(m => m.status === 'completed').length;
      const inProgress = filteredMilestones.filter(m => m.status === 'in-progress').length;
      const overdue = filteredMilestones.filter(m => 
        new Date(m.dueAt) < new Date() && m.status !== 'completed'
      ).length;

      this.animateValue('totalMilestones', 0, total, 1000);
      this.animateValue('completedMilestones', 0, completed, 1000);
      this.animateValue('inProgressMilestones', 0, inProgress, 1000);
      this.animateValue('overdueMilestones', 0, overdue, 1000);
    }

    private updateProjectProgress() {
      const container = document.getElementById('projectMilestoneProgress');
      if (!container) return;

      const projectGroups = this.groupMilestonesByProject();
      
      if (projectGroups.length === 0) {
        container.innerHTML = `
          <div class="text-center py-8">
            <i class="fas fa-project-diagram text-4xl text-slate-600 mb-4"></i>
            <p class="text-slate-400">No projects found</p>
          </div>
        `;
        return;
      }

      container.innerHTML = projectGroups.map(project => {
        const totalMilestones = project.milestones.length;
        const completedMilestones = project.milestones.filter((m: any) => m.status === 'completed').length;
        const progress = totalMilestones > 0 ? Math.round((completedMilestones / totalMilestones) * 100) : 0;

        return `
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-3">
                <div class="w-3 h-3 rounded-full ${this.getProjectStatusColor(project.status)}"></div>
                <span class="text-white font-medium">${project.name}</span>
                <span class="text-sm text-slate-400">${completedMilestones}/${totalMilestones} milestones</span>
              </div>
              <span class="text-sm font-medium ${progress >= 75 ? 'text-green-400' : progress >= 50 ? 'text-yellow-400' : 'text-red-400'}">${progress}%</span>
            </div>
            <div class="w-full bg-slate-700 rounded-full h-2">
              <div class="h-2 rounded-full transition-all duration-500 ${
                progress >= 75 ? 'bg-green-500' : 
                progress >= 50 ? 'bg-yellow-500' : 'bg-red-500'
              }" style="width: ${progress}%"></div>
            </div>
            ${project.milestones.length > 0 ? `
              <div class="flex flex-wrap gap-2 mt-2">
                ${project.milestones.slice(0, 5).map((milestone: any) => `
                  <span class="px-2 py-1 bg-slate-700 rounded text-xs text-slate-300">
                    ${milestone.title}
                  </span>
                `).join('')}
                ${project.milestones.length > 5 ? `
                  <span class="px-2 py-1 bg-slate-700 rounded text-xs text-slate-400">
                    +${project.milestones.length - 5} more
                  </span>
                ` : ''}
              </div>
            ` : ''}
          </div>
        `;
      }).join('');
    }

    private updateMilestoneTable() {
      const tbody = document.getElementById('milestoneTableBody');
      if (!tbody) return;

      const filteredMilestones = this.getFilteredMilestones();
      
      if (filteredMilestones.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="text-center py-8">
              <i class="fas fa-flag text-4xl text-slate-600 mb-4"></i>
              <p class="text-slate-400">No milestones found</p>
            </td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = filteredMilestones.map(milestone => `
        <tr class="border-b border-slate-800 hover:bg-slate-800/30 transition-colors">
          <td class="py-3 px-4">
            <div class="flex items-center space-x-2">
              <div class="w-2 h-2 rounded-full ${this.getStatusColor(milestone.status)}"></div>
              <span class="text-white">${milestone.title}</span>
            </div>
          </td>
          <td class="py-3 px-4 text-slate-300">${milestone.projectName}</td>
          <td class="py-3 px-4">
            <span class="text-slate-300">${new Date(milestone.dueAt).toLocaleDateString()}</span>
            ${new Date(milestone.dueAt) < new Date() && milestone.status !== 'completed' ? 
              '<span class="ml-2 text-xs text-red-400">Overdue</span>' : ''}
          </td>
          <td class="py-3 px-4">
            <span class="px-2 py-1 rounded-full text-xs ${this.getStatusClass(milestone.status)}">
              ${milestone.status}
            </span>
          </td>
          <td class="py-3 px-4">
            <div class="flex items-center space-x-2">
              <div class="w-16 bg-slate-700 rounded-full h-2">
                <div class="bg-blue-500 h-2 rounded-full" style="width: ${milestone.progress || 0}%"></div>
              </div>
              <span class="text-slate-400 text-sm">${milestone.progress || 0}%</span>
            </div>
          </td>
          <td class="py-3 px-4">
            <div class="flex items-center space-x-2">
              <div class="w-6 h-6 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white text-xs font-bold">
                ${(milestone.assignee?.name || 'Unassigned').charAt(0).toUpperCase()}
              </div>
              <span class="text-slate-300 text-sm">${milestone.assignee?.name || 'Unassigned'}</span>
            </div>
          </td>
          <td class="py-3 px-4">
            <div class="flex items-center space-x-2">
              <button class="p-1 hover:bg-slate-700 rounded transition-colors" onclick="milestoneTracker.editMilestone('${milestone.id}')" title="Edit">
                <i class="fas fa-edit text-slate-400 text-sm"></i>
              </button>
              <button class="p-1 hover:bg-slate-700 rounded transition-colors" onclick="milestoneTracker.viewDetails('${milestone.id}')" title="View Details">
                <i class="fas fa-eye text-slate-400 text-sm"></i>
              </button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    private getFilteredMilestones(): any[] {
      let filtered = this.milestones;
      
      if (this.currentFilter !== 'all') {
        filtered = filtered.filter(milestone => {
          const project = this.projects.find(p => p.id === milestone.projectId);
          return this.currentFilter === 'active' ? 
            project?.status === 'active' || project?.status === 'in-progress' :
            project?.status === this.currentFilter;
        });
      }
      
      return filtered.sort((a, b) => new Date(a.dueAt).getTime() - new Date(b.dueAt).getTime());
    }

    private groupMilestonesByProject() {
      const projectMap = new Map();
      
      this.projects.forEach(project => {
        projectMap.set(project.id, {
          id: project.id,
          name: project.name,
          status: project.status,
          milestones: []
        });
      });
      
      this.milestones.forEach(milestone => {
        const project = projectMap.get(milestone.projectId);
        if (project) {
          project.milestones.push(milestone);
        }
      });
      
      return Array.from(projectMap.values()).filter(project => project.milestones.length > 0);
    }

    private getProjectStatusColor(status: string): string {
      switch (status) {
        case 'active':
        case 'in-progress':
          return 'bg-blue-500';
        case 'completed':
          return 'bg-green-500';
        case 'on-hold':
          return 'bg-yellow-500';
        default:
          return 'bg-gray-500';
      }
    }

    private getStatusColor(status: string): string {
      switch (status) {
        case 'completed':
          return 'bg-green-500';
        case 'in-progress':
          return 'bg-blue-500';
        case 'overdue':
          return 'bg-red-500';
        default:
          return 'bg-gray-500';
      }
    }

    private getStatusClass(status: string): string {
      switch (status) {
        case 'completed':
          return 'bg-green-500/20 text-green-400';
        case 'in-progress':
          return 'bg-blue-500/20 text-blue-400';
        case 'overdue':
          return 'bg-red-500/20 text-red-400';
        default:
          return 'bg-gray-500/20 text-gray-400';
      }
    }

    private animateValue(elementId: string, start: number, end: number, duration: number) {
      const element = document.getElementById(elementId);
      if (!element) return;

      const range = end - start;
      const increment = range / (duration / 16);
      let current = start;

      const timer = setInterval(() => {
        current += increment;
        if ((increment > 0 && current >= end) || (increment < 0 && current <= end)) {
          current = end;
          clearInterval(timer);
        }
        element.textContent = Math.round(current).toString();
      }, 16);
    }

    private setupEventListeners() {
      document.getElementById('milestoneFilter')?.addEventListener('change', (e: any) => {
        this.currentFilter = e.target.value;
        this.updateUI();
      });

      // Listen for real-time updates
      window.addEventListener('projects-data-updated', () => {
        this.loadData();
      });
    }

    private loadMockData() {
      this.milestones = [
        {
          id: '1',
          title: 'Design System Implementation',
          dueAt: '2024-12-20',
          status: 'in-progress',
          progress: 65,
          projectName: 'E-commerce Platform',
          projectId: '1',
          assignee: { name: 'Jane Smith' }
        },
        {
          id: '2',
          title: 'Payment Gateway Integration',
          dueAt: '2024-12-15',
          status: 'overdue',
          progress: 80,
          projectName: 'E-commerce Platform',
          projectId: '1',
          assignee: { name: 'Mike Johnson' }
        },
        {
          id: '3',
          title: 'Mobile App Wireframes',
          dueAt: '2024-12-25',
          status: 'completed',
          progress: 100,
          projectName: 'Mobile Banking App',
          projectId: '2',
          assignee: { name: 'Sarah Wilson' }
        }
      ];

      this.projects = [
        { id: '1', name: 'E-commerce Platform', status: 'active' },
        { id: '2', name: 'Mobile Banking App', status: 'active' }
      ];

      this.updateUI();
    }

    // Public methods
    refresh() {
      this.loadData();
    }

    exportData() {
      const data = {
        exportDate: new Date().toISOString(),
        milestones: this.getFilteredMilestones(),
        projects: this.projects
      };

      const dataStr = JSON.stringify(data, null, 2);
      const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
      
      const exportFileDefaultName = `milestone-tracker-${new Date().toISOString().split('T')[0]}.json`;
      
      const linkElement = document.createElement('a');
      linkElement.setAttribute('href', dataUri);
      linkElement.setAttribute('download', exportFileDefaultName);
      linkElement.click();
    }

    editMilestone(milestoneId: string) {
      console.log('Editing milestone:', milestoneId);
      // Open edit modal
    }

    viewDetails(milestoneId: string) {
      console.log('Viewing milestone details:', milestoneId);
      // Open details modal
    }
  }

  // Initialize milestone tracker when component loads
  document.addEventListener('DOMContentLoaded', () => {
    (window as any).milestoneTracker = new MilestoneTracker();
  });
</script>


---