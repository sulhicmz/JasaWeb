---
// Project Timeline Component
---

<div class="space-y-4">
  <!-- Timeline Filters -->
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <select id="timelineFilter" class="bg-slate-800 text-white px-3 py-2 rounded-lg border border-slate-700 focus:border-blue-500 focus:outline-none text-sm">
        <option value="upcoming">Upcoming</option>
        <option value="overdue">Overdue</option>
        <option value="completed">Completed</option>
        <option value="all">All Milestones</option>
      </select>
      <select id="timelineSort" class="bg-slate-800 text-white px-3 py-2 rounded-lg border border-slate-700 focus:border-blue-500 focus:outline-none text-sm">
        <option value="date">Sort by Date</option>
        <option value="priority">Sort by Priority</option>
        <option value="project">Sort by Project</option>
      </select>
    </div>
    <button id="addMilestone" class="px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors text-sm flex items-center space-x-2">
      <i class="fas fa-plus"></i>
      <span>Add Milestone</span>
    </button>
  </div>

  <!-- Timeline View -->
  <div class="relative">
    <!-- Timeline Line -->
    <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-slate-700"></div>
    
    <!-- Timeline Items -->
    <div id="timelineItems" class="space-y-6">
      <!-- Timeline items will be populated here -->
    </div>
  </div>

  <!-- Load More -->
  <div class="text-center">
    <button id="loadMoreMilestones" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white rounded-lg transition-colors text-sm">
      Load More
    </button>
  </div>
</div>

<script>
  class ProjectTimeline {
    private milestones: any[] = [];
    private projects: any[] = [];
    private currentFilter = 'upcoming';
    private currentSort = 'date';
    private itemsPerPage = 10;
    private currentPage = 1;

    constructor() {
      this.loadData();
      this.setupEventListeners();
    }

    private async loadData() {
      try {
        // Load projects
        const projectsResponse = await fetch('/api/dashboard/projects-overview');
        this.projects = await projectsResponse.json();

        // Load milestones
        const milestonesResponse = await fetch('/api/milestones');
        this.milestones = await milestonesResponse.json();

        // Enrich milestones with project data
        this.milestones = this.milestones.map((milestone: any) => {
          const project = this.projects.find(p => p.id === milestone.projectId);
          return {
            ...milestone,
            projectName: project?.name || 'Unknown Project',
            projectStatus: project?.status || 'unknown'
          };
        });

        this.renderTimeline();
      } catch (error) {
        console.error('Failed to load timeline data:', error);
        this.loadMockData();
      }
    }

    private renderTimeline() {
      const container = document.getElementById('timelineItems');
      if (!container) return;

      const filteredMilestones = this.getFilteredMilestones();
      const sortedMilestones = this.getSortedMilestones(filteredMilestones);
      const paginatedMilestones = this.getPaginatedMilestones(sortedMilestones);

      if (paginatedMilestones.length === 0) {
        container.innerHTML = `
          <div class="text-center py-12">
            <i class="fas fa-flag text-4xl text-slate-600 mb-4"></i>
            <h3 class="text-lg font-medium text-slate-400 mb-2">No milestones found</h3>
            <p class="text-slate-500">No milestones match your current filters.</p>
          </div>
        `;
        return;
      }

      container.innerHTML = paginatedMilestones.map(milestone => this.createTimelineItem(milestone)).join('');

      // Add animations
      this.animateTimelineItems();
    }

    private createTimelineItem(milestone: any): string {
      const statusColor = this.getStatusColor(milestone.status);
      const priorityIcon = this.getPriorityIcon(milestone.priority);
      const isOverdue = new Date(milestone.dueAt) < new Date() && milestone.status !== 'completed';
      
      return `
        <div class="relative flex items-start space-x-6 timeline-item animate-slide-in">
          <!-- Timeline Dot -->
          <div class="relative flex-shrink-0">
            <div class="w-16 h-16 rounded-full ${statusColor} flex items-center justify-center border-4 border-slate-900">
              <i class="fas ${this.getMilestoneIcon(milestone.status)} text-white text-lg"></i>
            </div>
            ${isOverdue ? '<div class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-slate-900"></div>' : ''}
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <div class="glass-panel p-6 rounded-xl">
              <div class="flex items-start justify-between mb-4">
                <div class="flex-1">
                  <div class="flex items-center space-x-3 mb-2">
                    <h3 class="text-white font-medium">${milestone.title}</h3>
                    ${priorityIcon}
                    ${milestone.priority === 'critical' ? '<span class="px-2 py-1 bg-red-500/20 text-red-400 rounded-full text-xs">Critical</span>' : ''}
                    ${isOverdue ? '<span class="px-2 py-1 bg-red-500/20 text-red-400 rounded-full text-xs">Overdue</span>' : ''}
                  </div>
                  <div class="flex items-center space-x-4 text-sm text-slate-400">
                    <span class="flex items-center space-x-1">
                      <i class="fas fa-project-diagram"></i>
                      <span>${milestone.projectName}</span>
                    </span>
                    <span class="flex items-center space-x-1">
                      <i class="fas fa-calendar"></i>
                      <span>${new Date(milestone.dueAt).toLocaleDateString()}</span>
                    </span>
                    <span class="flex items-center space-x-1">
                      <i class="fas fa-clock"></i>
                      <span>${this.getTimeRemaining(milestone.dueAt)}</span>
                    </span>
                  </div>
                </div>
                <div class="flex items-center space-x-2">
                  <button class="p-2 hover:bg-slate-700 rounded-lg transition-colors" onclick="projectTimeline.editMilestone('${milestone.id}')" title="Edit">
                    <i class="fas fa-edit text-slate-400"></i>
                  </button>
                  <button class="p-2 hover:bg-slate-700 rounded-lg transition-colors" onclick="projectTimeline.completeMilestone('${milestone.id}')" title="Mark Complete">
                    <i class="fas fa-check text-slate-400"></i>
                  </button>
                  <button class="p-2 hover:bg-slate-700 rounded-lg transition-colors" onclick="projectTimeline.deleteMilestone('${milestone.id}')" title="Delete">
                    <i class="fas fa-trash text-slate-400"></i>
                  </button>
                </div>
              </div>

              <!-- Progress Bar -->
              <div class="space-y-2">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-slate-400">Progress</span>
                  <span class="text-white">${milestone.progress || 0}%</span>
                </div>
                <div class="w-full bg-slate-700 rounded-full h-2">
                  <div class="bg-gradient-to-r from-blue-500 to-indigo-600 h-2 rounded-full transition-all duration-500" style="width: ${milestone.progress || 0}%"></div>
                </div>
              </div>

              <!-- Dependencies -->
              ${milestone.dependencies && milestone.dependencies.length > 0 ? `
                <div class="mt-4 pt-4 border-t border-slate-700">
                  <div class="text-sm text-slate-400 mb-2">Dependencies:</div>
                  <div class="flex flex-wrap gap-2">
                    ${milestone.dependencies.map((dep: any) => `
                      <span class="px-2 py-1 bg-slate-700 text-slate-300 rounded text-xs">${dep.title}</span>
                    `).join('')}
                  </div>
                </div>
              ` : ''}

              <!-- Assignees -->
              ${milestone.assignees && milestone.assignees.length > 0 ? `
                <div class="mt-4 pt-4 border-t border-slate-700">
                  <div class="text-sm text-slate-400 mb-2">Assigned to:</div>
                  <div class="flex items-center space-x-2">
                    ${milestone.assignees.map((assignee: any) => `
                      <div class="flex items-center space-x-2 px-2 py-1 bg-slate-700 rounded">
                        <div class="w-6 h-6 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white text-xs font-bold">
                          ${assignee.name.split(' ').map((n: string) => n[0]).join('')}
                        </div>
                        <span class="text-white text-xs">${assignee.name}</span>
                      </div>
                    `).join('')}
                  </div>
                </div>
              ` : ''}
            </div>
          </div>
        </div>
      `;
    }

    private getStatusColor(status: string): string {
      switch (status) {
        case 'completed':
          return 'bg-green-500';
        case 'in-progress':
          return 'bg-blue-500';
        case 'overdue':
          return 'bg-red-500';
        default:
          return 'bg-slate-600';
      }
    }

    private getMilestoneIcon(status: string): string {
      switch (status) {
        case 'completed':
          return 'fa-check';
        case 'in-progress':
          return 'fa-spinner';
        case 'overdue':
          return 'fa-exclamation-triangle';
        default:
          return 'fa-flag';
      }
    }

    private getPriorityIcon(priority: string): string {
      switch (priority) {
        case 'critical':
          return '<i class="fas fa-exclamation-circle text-red-400"></i>';
        case 'high':
          return '<i class="fas fa-arrow-up text-orange-400"></i>';
        case 'medium':
          return '<i class="fas fa-minus text-yellow-400"></i>';
        case 'low':
          return '<i class="fas fa-arrow-down text-green-400"></i>';
        default:
          return '';
      }
    }

    private getTimeRemaining(dueDate: string): string {
      const now = new Date();
      const due = new Date(dueDate);
      const diffTime = due.getTime() - now.getTime();
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

      if (diffDays < 0) {
        return `${Math.abs(diffDays)} days overdue`;
      } else if (diffDays === 0) {
        return 'Due today';
      } else if (diffDays === 1) {
        return 'Due tomorrow';
      } else if (diffDays <= 7) {
        return `${diffDays} days`;
      } else {
        return `${Math.ceil(diffDays / 7)} weeks`;
      }
    }

    private getFilteredMilestones(): any[] {
      const now = new Date();
      
      switch (this.currentFilter) {
        case 'upcoming':
          return this.milestones.filter(m => 
            new Date(m.dueAt) >= now && m.status !== 'completed'
          );
        case 'overdue':
          return this.milestones.filter(m => 
            new Date(m.dueAt) < now && m.status !== 'completed'
          );
        case 'completed':
          return this.milestones.filter(m => m.status === 'completed');
        default:
          return this.milestones;
      }
    }

    private getSortedMilestones(milestones: any[]): any[] {
      const sorted = [...milestones];
      
      switch (this.currentSort) {
        case 'date':
          return sorted.sort((a, b) => new Date(a.dueAt).getTime() - new Date(b.dueAt).getTime());
        case 'priority':
          const priorityOrder = { critical: 0, high: 1, medium: 2, low: 3 };
          return sorted.sort((a, b) => priorityOrder[a.priority] - priorityOrder[b.priority]);
        case 'project':
          return sorted.sort((a, b) => a.projectName.localeCompare(b.projectName));
        default:
          return sorted;
      }
    }

    private getPaginatedMilestones(milestones: any[]): any[] {
      const start = (this.currentPage - 1) * this.itemsPerPage;
      const end = start + this.itemsPerPage;
      return milestones.slice(start, end);
    }

    private animateTimelineItems() {
      const items = document.querySelectorAll('.timeline-item');
      items.forEach((item, index) => {
        (item as HTMLElement).style.animationDelay = `${index * 0.1}s`;
      });
    }

    private setupEventListeners() {
      // Filter change
      document.getElementById('timelineFilter')?.addEventListener('change', (e: any) => {
        this.currentFilter = e.target.value;
        this.currentPage = 1;
        this.renderTimeline();
      });

      // Sort change
      document.getElementById('timelineSort')?.addEventListener('change', (e: any) => {
        this.currentSort = e.target.value;
        this.renderTimeline();
      });

      // Add milestone
      document.getElementById('addMilestone')?.addEventListener('click', () => {
        this.addMilestone();
      });

      // Load more
      document.getElementById('loadMoreMilestones')?.addEventListener('click', () => {
        this.currentPage++;
        this.renderTimeline();
      });
    }

    private loadMockData() {
      this.milestones = [
        {
          id: '1',
          title: 'Design System Implementation',
          dueAt: '2024-12-20',
          status: 'in-progress',
          priority: 'high',
          progress: 65,
          projectName: 'E-commerce Platform',
          projectId: '1',
          assignees: [{ name: 'Jane Smith' }, { name: 'John Doe' }],
          dependencies: []
        },
        {
          id: '2',
          title: 'Payment Gateway Integration',
          dueAt: '2024-12-15',
          status: 'overdue',
          priority: 'critical',
          progress: 80,
          projectName: 'E-commerce Platform',
          projectId: '1',
          assignees: [{ name: 'Mike Johnson' }],
          dependencies: [{ title: 'Design System Implementation' }]
        },
        {
          id: '3',
          title: 'Mobile App Wireframes',
          dueAt: '2024-12-25',
          status: 'completed',
          priority: 'medium',
          progress: 100,
          projectName: 'Mobile Banking App',
          projectId: '2',
          assignees: [{ name: 'Sarah Wilson' }],
          dependencies: []
        }
      ];

      this.renderTimeline();
    }

    // Public methods
    editMilestone(milestoneId: string) {
      console.log('Editing milestone:', milestoneId);
      // Open edit modal
    }

    completeMilestone(milestoneId: string) {
      console.log('Completing milestone:', milestoneId);
      // Mark milestone as complete
    }

    deleteMilestone(milestoneId: string) {
      if (confirm('Are you sure you want to delete this milestone?')) {
        console.log('Deleting milestone:', milestoneId);
        // Delete milestone
      }
    }

    addMilestone() {
      console.log('Adding new milestone');
      // Open add milestone modal
    }
  }

  // Initialize timeline when component loads
  document.addEventListener('DOMContentLoaded', () => {
    (window as any).projectTimeline = new ProjectTimeline();
  });
</script>


---