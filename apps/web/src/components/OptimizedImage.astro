---
// src/components/OptimizedImage.astro
export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  class?: string;
  sizes?: string;
  priority?: boolean;
}

const { 
  src, 
  alt, 
  width, 
  height, 
  loading = 'lazy', 
  class: className = '', 
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  priority = false 
} = Astro.props;

// Generate responsive image sizes with modern format support
const generateSrcSet = (format: string) => {
  if (typeof width !== 'number') return undefined;
  const sizes = [0.5, 1, 1.5, 2];
  return sizes.map(scale => 
    `${src}?w=${Math.round(width * scale)}&format=${format}&q=80 ${Math.round(width * scale)}w`
  ).join(', ');
};

const webpSrcSet = generateSrcSet('webp');
const avifSrcSet = generateSrcSet('avif');
const fallbackSrcSet = typeof width === 'number' ? [
  `${src}?w=${Math.round(width * 0.5)}&q=75 ${Math.round(width * 0.5)}w`,
  `${src}?w=${width}&q=75 ${width}w`,
  `${src}?w=${Math.round(width * 1.5)}&q=75 ${Math.round(width * 1.5)}w`,
  `${src}?w=${Math.round(width * 2)}&q=75 ${Math.round(width * 2)}w`
].join(', ') : undefined;
---

{priority ? (
  <!-- Priority image with preload -->
  <link rel="preload" as="image" href={src} />
) : null}

<picture>
  <!-- AVIF format - best compression -->
  <source 
    type="image/avif" 
    srcset={avifSrcSet}
    sizes={sizes}
  />
  <!-- WebP format - wide support -->
  <source 
    type="image/webp" 
    srcset={webpSrcSet}
    sizes={sizes}
  />
  <!-- Fallback for older browsers -->
  <img 
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={priority ? 'eager' : loading}
    decoding={priority ? 'sync' : 'async'}
    class={`transition-opacity duration-300 ${className}`}
    sizes={sizes}
    srcset={fallbackSrcSet}
    style={`
      content-visibility: ${priority ? 'visible' : 'auto'}; 
      contain-intrinsic-size: ${width || 400}px ${height || 300}px;
      will-change: opacity;
      image-rendering: -webkit-optimize-contrast;
      image-rendering: crisp-edges;
    `}
    onload="this.classList.add('loaded')"
    onerror="this.classList.add('error'); this.src='/images/placeholder.jpg';"
    fetchpriority={priority ? 'high' : 'auto'}
  />
</picture>

<noscript>
  <img 
    src={src} 
    alt={alt} 
    width={width} 
    height={height}
    class={className}
    loading="eager"
  />
</noscript>