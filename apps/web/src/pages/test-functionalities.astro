---
// src/pages/test-functionalities.astro
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Test Functionalities - JasaWeb';
---

<Layout title="Test Functionalities">
  <div class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="bg-white rounded-lg shadow-lg p-8">
        <h1 class="text-3xl font-bold text-center mb-8">Test Functionalities</h1>
        
        <div class="space-y-8">
          <!-- Navigation Test -->
          <div class="border-b border-gray-200 pb-6">
            <h2 class="text-xl font-semibold mb-4">Navigation Test</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <a href="/" class="bg-blue-100 text-blue-800 py-2 px-4 rounded text-center hover:bg-blue-200 transition">Home</a>
              <a href="/about" class="bg-blue-100 text-blue-800 py-2 px-4 rounded text-center hover:bg-blue-200 transition">About</a>
              <a href="/services" class="bg-blue-100 text-blue-800 py-2 px-4 rounded text-center hover:bg-blue-200 transition">Services</a>
              <a href="/contact" class="bg-blue-100 text-blue-800 py-2 px-4 rounded text-center hover:bg-blue-200 transition">Contact</a>
              <a href="/blog" class="bg-blue-100 text-blue-800 py-2 px-4 rounded text-center hover:bg-blue-200 transition">Blog</a>
              <a href="/portfolio" class="bg-blue-100 text-blue-800 py-2 px-4 rounded text-center hover:bg-blue-200 transition">Portfolio</a>
              <a href="/portal" class="bg-indigo-100 text-indigo-800 py-2 px-4 rounded text-center hover:bg-indigo-200 transition">Portal</a>
              <a href="/login" class="bg-indigo-100 text-indigo-800 py-2 px-4 rounded text-center hover:bg-indigo-200 transition">Login</a>
            </div>
          </div>
          
          <!-- Form Test -->
          <div class="border-b border-gray-200 pb-6">
            <h2 class="text-xl font-semibold mb-4">Form Test</h2>
            <form id="testForm" class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input type="text" id="name" name="name" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Your name" required>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" id="email" name="email" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Your email" required>
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service</label>
                <select id="service" name="service" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                  <option value="">Select a service</option>
                  <option value="school">Website Sekolah</option>
                  <option value="news">Portal Berita</option>
                  <option value="company">Company Profile</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                <textarea id="message" name="message" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Your message" required></textarea>
              </div>
              <button type="submit" class="bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition">Submit</button>
            </form>
          </div>
          
          <!-- Component Test -->
          <div class="border-b border-gray-200 pb-6">
            <h2 class="text-xl font-semibold mb-4">Component Test</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-gray-100 p-4 rounded-lg">
                <h3 class="font-medium mb-2">Alert Component</h3>
                <div id="alertPlaceholder"></div>
                <button onclick="showAlert()" class="bg-green-600 text-white py-1 px-3 rounded text-sm">Show Alert</button>
              </div>
              <div class="bg-gray-100 p-4 rounded-lg">
                <h3 class="font-medium mb-2">Modal Component</h3>
                <button onclick="openModal()" class="bg-purple-600 text-white py-1 px-3 rounded text-sm">Open Modal</button>
              </div>
            </div>
          </div>
          
          <!-- API Integration Test -->
          <div class="border-b border-gray-200 pb-6">
            <h2 class="text-xl font-semibold mb-4">API Integration Test</h2>
            <div class="space-y-4">
              <button onclick="testAPI()" class="bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition">Test API Connection</button>
              <div id="apiResult" class="mt-2 p-3 bg-gray-100 rounded hidden"></div>
            </div>
          </div>
          
          <!-- Responsive Test -->
          <div class="pb-6">
            <h2 class="text-xl font-semibold mb-4">Responsive Elements Test</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
              <div class="bg-blue-50 p-4 rounded text-center">Col 1</div>
              <div class="bg-green-50 p-4 rounded text-center">Col 2</div>
              <div class="bg-yellow-50 p-4 rounded text-center">Col 3</div>
              <div class="bg-red-50 p-4 rounded text-center">Col 4</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="testModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
      <div class="mt-3">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Test Modal</h3>
        <p class="text-sm text-gray-600 mb-4">This is a test modal to verify modal functionality.</p>
        <div class="flex justify-end space-x-3">
          <button onclick="closeModal()" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-gray-300">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Form submission handler
    document.getElementById('testForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      const data = Object.fromEntries(formData);
      showAlert('Form submitted successfully!', 'success');
      console.log('Form data:', data);
      this.reset();
    });

    // Show alert function
    function showAlert(message = 'Test alert message', type = 'info') {
      const alertDiv = document.createElement('div');
      let bgColor = 'bg-blue-100';
      let textColor = 'text-blue-800';
      
      if (type === 'success') {
        bgColor = 'bg-green-100';
        textColor = 'text-green-800';
      } else if (type === 'error') {
        bgColor = 'bg-red-100';
        textColor = 'text-red-800';
      } else if (type === 'warning') {
        bgColor = 'bg-yellow-100';
        textColor = 'text-yellow-800';
      }
      
      alertDiv.className = `p-3 mb-3 rounded ${bgColor} ${textColor} text-sm`;
      alertDiv.textContent = message;
      
      const placeholder = document.getElementById('alertPlaceholder');
      placeholder.innerHTML = '';
      placeholder.appendChild(alertDiv);
      
      // Remove alert after 5 seconds
      setTimeout(() => {
        if (placeholder.contains(alertDiv)) {
          placeholder.removeChild(alertDiv);
        }
      }, 5000);
    }

    // Modal functions
    function openModal() {
      document.getElementById('testModal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('testModal').classList.add('hidden');
    }

    // API test function
    async function testAPI() {
      const resultDiv = document.getElementById('apiResult');
      resultDiv.classList.remove('hidden');
      resultDiv.textContent = 'Testing API connection...';
      resultDiv.className = 'mt-2 p-3 bg-yellow-100 text-yellow-800 rounded';
      
      try {
        // This would be replaced with actual API endpoint
        // For now, we'll simulate a test with a timeout
        await new Promise(resolve => setTimeout(resolve, 1000));
        resultDiv.textContent = 'API connection successful!';
        resultDiv.className = 'mt-2 p-3 bg-green-100 text-green-800 rounded';
      } catch (error) {
        resultDiv.textContent = 'API connection failed: ' + error.message;
        resultDiv.className = 'mt-2 p-3 bg-red-100 text-red-800 rounded';
      }
    }

    // Close modals when clicking outside
    window.onclick = function(event) {
      const modal = document.getElementById('testModal');
      if (event.target === modal) {
        modal.classList.add('hidden');
      }
    }

    // Initialize with some test data
    document.addEventListener('DOMContentLoaded', function() {
      console.log('Frontend functionality test page loaded');
      // You can add initialization code here if needed
    });
  </script>
</Layout>