# =============================================================================
# JasaWeb Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# Note: Frontend environment variables must be prefixed with PUBLIC_ to be exposed to the browser

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application Metadata
PUBLIC_APP_NAME=JasaWeb
PUBLIC_APP_VERSION=1.0.0
PUBLIC_APP_DESCRIPTION=Professional Web Development Services
PUBLIC_APP_AUTHOR=JasaWeb Team

# Site URLs
PUBLIC_BASE_URL=http://localhost:4321
PUBLIC_ENVIRONMENT=development

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API URL - Critical for frontend-backend communication
PUBLIC_API_URL=http://localhost:3000
PUBLIC_API_PREFIX=api
PUBLIC_API_VERSION=v1
PUBLIC_API_TIMEOUT=10000

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
# Company Information
PUBLIC_COMPANY_NAME=JasaWeb
PUBLIC_COMPANY_EMAIL=contact@jasaweb.com
PUBLIC_COMPANY_PHONE=+62-21-1234-5678
PUBLIC_COMPANY_ADDRESS=Jakarta, Indonesia
PUBLIC_COMPANY_WEBSITE=https://jasaweb.com

# Service Pricing (in Indonesian Rupiah)
PUBLIC_SCHOOL_WEBSITE_BASE_PRICE=15000000
PUBLIC_SCHOOL_WEBSITE_DELIVERY_WEEKS=8
PUBLIC_NEWS_PORTAL_BASE_PRICE=20000000
PUBLIC_NEWS_PORTAL_DELIVERY_WEEKS=10
PUBLIC_COMPANY_PROFILE_BASE_PRICE=10000000
PUBLIC_COMPANY_PROFILE_DELIVERY_WEEKS=6

# =============================================================================
# UI/UX CONFIGURATION
# =============================================================================
# Theme Configuration
PUBLIC_PRIMARY_COLOR=#3b82f6
PUBLIC_SECONDARY_COLOR=#64748b
PUBLIC_ACCENT_COLOR=#f59e0b
PUBLIC_DARK_MODE=true

# Animation Settings
PUBLIC_ANIMATIONS_ENABLED=true
PUBLIC_ANIMATION_DURATION=300

# Feature Toggles
PUBLIC_ANALYTICS_ENABLED=true
PUBLIC_CHAT_ENABLED=true
PUBLIC_NOTIFICATIONS_ENABLED=true
PUBLIC_DARK_MODE_TOGGLE=true

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# Google Analytics (optional)
PUBLIC_GOOGLE_ANALYTICS_ID=
PUBLIC_GOOGLE_TAG_MANAGER_ID=

# Sentry Error Monitoring (optional)
PUBLIC_SENTRY_DSN=

# Monitoring Settings
PUBLIC_MONITORING_ENABLED=true
PUBLIC_DEBUG_MODE=false

# =============================================================================
# SEO & SOCIAL MEDIA
# =============================================================================
# SEO Configuration
PUBLIC_META_TITLE=JasaWeb - Professional Web Development Services
PUBLIC_META_DESCRIPTION=Professional web development services for schools, news portals, and company profiles
PUBLIC_META_KEYWORDS=web development, website design, school website, news portal, company profile
PUBLIC_OG_IMAGE=/images/og-image.jpg

# Social Media Links (optional)
PUBLIC_FACEBOOK_URL=
PUBLIC_TWITTER_URL=
PUBLIC_INSTAGRAM_URL=
PUBLIC_LINKEDIN_URL=

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Development Settings
PUBLIC_DEV_MODE=true
PUBLIC_LOG_LEVEL=info

# Feature Flags for Development
PUBLIC_ENABLE_BLOG=true
PUBLIC_ENABLE_PORTFOLIO=true
PUBLIC_ENABLE_CONTACT_FORM=true

# =============================================================================
# PRODUCTION CONFIGURATION NOTES
# =============================================================================
# When deploying to production:
# 1. Update PUBLIC_API_URL to your production API endpoint
# 2. Update PUBLIC_BASE_URL to your production domain
# 3. Set PUBLIC_ENVIRONMENT=production
# 4. Configure analytics and monitoring services
# 5. Update social media URLs
# 6. Review and adjust pricing if needed
# 7. Ensure all PUBLIC_ variables are appropriate for production exposure

# =============================================================================
# SECURITY NOTES
# =============================================================================
# - Only use PUBLIC_ prefix for variables that need to be exposed to the browser
# - Never put sensitive secrets (API keys, passwords) in PUBLIC_ variables
# - Backend secrets should be configured in the API environment, not frontend
# - Use HTTPS URLs in production
# - Validate all user inputs on the backend regardless of frontend configuration